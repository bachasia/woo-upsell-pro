$opts          = $bmsm_data['options']        ?? [];

if ( empty( $tiers ) ) {
	return;
}

$is_items    = $conditional === 'items';
$heading_en  = ( $opts['heading_enable'] ?? 'yes' ) === 'yes';
$hide_congrats = ( $opts['hide_congrats'] ?? 'no' ) === 'yes';
$hide_remain   = ( $opts['hide_remain'] ?? 'no' ) === 'yes';
