/* WUP Slide Side Cart */

#wup-side-cart {

    .wup-sc-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        z-index: 9998;
    }

    .wup-sc-panel,
    .wup-sc-content {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        width: 380px;
        max-width: 100vw;
        background: #fff;
        z-index: 9999;
        transform: translateX(100%);
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    &.wup-sc-open {
        .wup-sc-overlay { display: block; }

        .wup-sc-panel,
        .wup-sc-content {
            transform: translateX(0);
